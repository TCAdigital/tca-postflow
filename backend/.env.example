# TCA PostFlow - Variáveis de ambiente
# Renomeie este arquivo para .env antes de rodar

# Porta do servidor (Railway/Render detectam automaticamente)
PORT=3001

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# Gemini API Key - obter em: https://aistudio.google.com/app/apikey (GRATUITO)
GEMINI_API_KEY=sua_chave_aqui

# JWT Secret - use qualquer string longa e aleatória
JWT_SECRET=tca_postflow_super_secret_mude_isso_em_producao_2024
